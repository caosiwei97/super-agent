# OpenAI-compatible model
OPENAI_API_KEY=your-key
MODEL_BASE_URL=https://api.deepseek.com
MODEL_ID=deepseek-v4-flash

# Agent runtime
TOKEN_BUDGET=1000000
AGENT_MAX_STEPS=15
AGENT_MAX_RETRIES=10
AGENT_TURN_TIMEOUT_MS=120000
MODEL_REQUEST_TIMEOUT_MS=60000
# Development may use '.'. Production must use a dedicated clean directory;
# keep this file and every provider credential outside that workspace.
SUPER_AGENT_WORKSPACE=.
SUPER_AGENT_AUTO_APPROVE=false

# Immutable layout-v1 Session Storage contract. Omit these values when
# reopening an existing session unless you intend to assert an exact match.
# Byte counts include the terminating JSONL LF where applicable.
SUPER_AGENT_SESSION_MAX_RECORD_BYTES=1048576
SUPER_AGENT_SESSION_MAX_READ_RECORD_BYTES=16777216
SUPER_AGENT_SESSION_SEGMENT_TARGET_BYTES=16777216
SUPER_AGENT_SESSION_REGULAR_QUOTA_BYTES=67108864
SUPER_AGENT_SESSION_CRITICAL_RESERVE_BYTES=16777216

# Execution profile. Production requires Linux plus every sandbox and
# FilesystemBroker prerequisite; unsupported hosts fail before MCP/session/model setup.
SUPER_AGENT_EXECUTION_PROFILE=development
SUPER_AGENT_BWRAP_PATH=/usr/bin/bwrap
SUPER_AGENT_MKFIFO_PATH=/usr/bin/mkfifo
SUPER_AGENT_SANDBOX_ROOTFS=
SUPER_AGENT_SANDBOX_SECCOMP_PROFILE=
SUPER_AGENT_SANDBOX_SECCOMP_SHA256=
# A process-free delegated cgroup v2 root, not the Agent's runtime leaf.
SUPER_AGENT_SANDBOX_CGROUP_ROOT=
# Deployment attestation declaration only; production still requires an
# external systemd/OCI crash-reaping test.
SUPER_AGENT_SANDBOX_CRASH_SUPERVISOR=
SUPER_AGENT_SANDBOX_MAX_MEMORY_BYTES=1073741824
SUPER_AGENT_SANDBOX_MAX_SWAP_BYTES=0
SUPER_AGENT_SANDBOX_MAX_PIDS=64
SUPER_AGENT_SANDBOX_MAX_CPU_MICROS_PER_SECOND=1000000
SUPER_AGENT_SANDBOX_MAX_OPEN_FILES=4096
# Required in production: a dedicated current-UID-owned private directory.
SUPER_AGENT_SANDBOX_STAGING_PARENT=
SUPER_AGENT_SANDBOX_SNAPSHOT_MAX_FILES=10000
SUPER_AGENT_SANDBOX_SNAPSHOT_MAX_ENTRIES=20000
SUPER_AGENT_SANDBOX_SNAPSHOT_MAX_TOTAL_BYTES=268435456
SUPER_AGENT_SANDBOX_SNAPSHOT_MAX_FILE_BYTES=16777216
SUPER_AGENT_SANDBOX_SNAPSHOT_MAX_DEPTH=64

# Context compaction
CONTEXT_TOKEN_THRESHOLD=12000
CONTEXT_KEEP_RECENT_MESSAGES=8
CONTEXT_KEEP_RECENT_TOOL_MESSAGES=4
CONTEXT_ASCII_CHARS_PER_TOKEN=4
CONTEXT_MAX_SUMMARY_CHARS=1200

# GitHub hosted MCP
GITHUB_PERSONAL_ACCESS_TOKEN=
