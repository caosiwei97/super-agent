{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "declaration": true,
        "sourceMap": true,
        "inlineSources": true,
        "esModuleInterop": true,
        "outDir": "dist",
        "rootDir": "src",
        "types": ["node"]
    },
    "include": [
        "src"
    ]
}
